---
import Base from '../layouts/Base.astro';
import { supabase, type Testimonial, type Faq } from '../lib/supabase';

const { data: testimonials } = await supabase
  .from('testimonials')
  .select('*')
  .order('position', { ascending: true });

const { data: faqs } = await supabase
  .from('faqs')
  .select('*')
  .order('position', { ascending: true });

const features = [
  {
    icon: '🔎',
    title: 'AI semantic search',
    body: 'Ask questions in plain English and get answers sourced from your own docs, threads and decisions — not a generic LLM hallucination.',
  },
  {
    icon: '🧵',
    title: 'Threaded discussions',
    body: 'Every doc has its own thread. Decisions stop getting buried in Slack because they live where the knowledge lives.',
  },
  {
    icon: '🔌',
    title: 'Deep integrations',
    body: 'Two-way sync with Notion, Linear, GitHub, Slack and Google Drive. Import everything in an afternoon.',
  },
  {
    icon: '🛡️',
    title: 'Granular permissions',
    body: 'Role-based access, SSO on Enterprise, audit logs, and per-space visibility. Ready for security-conscious orgs.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: (faqs ?? []).map((f: Faq) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---
<Base
  title="Threadwise — AI team knowledge base with threaded discussions"
  description="Threadwise replaces Notion, Confluence and Slack search with one AI-powered knowledge base. Threaded discussions on every doc. Pricing from £9/seat/month."
  jsonLd={faqJsonLd}
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-60"></div>
    <div class="absolute inset-x-0 top-0 h-[600px] bg-gradient-to-b from-indigo-500/10 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32 text-center">
      <a href="/pricing" class="inline-flex items-center gap-2 text-xs px-3 py-1.5 rounded-full border border-indigo-400/30 bg-indigo-400/10 text-indigo-200 hover:bg-indigo-400/15 transition">
        <span class="inline-block w-1.5 h-1.5 bg-cyan-400 rounded-full animate-pulse"></span>
        New: AI search v2 is live · See pricing →
      </a>
      <h1 class="mt-6 text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.05]">
        Team knowledge,<br/>
        <span class="gradient-text">threaded.</span>
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg md:text-xl text-[color:var(--color-muted)]">
        Threadwise is the AI-powered knowledge base with threaded discussions on every doc.
        Stop losing decisions in Slack. Stop searching four tools. One place, one search, one source of truth.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/pricing" class="px-6 py-3 rounded-lg bg-[color:var(--color-brand)] hover:bg-[color:var(--color-brand-hover)] text-white font-semibold shadow-lg shadow-indigo-500/30 transition">
          Start 14-day free trial
        </a>
        <a href="#features" class="px-6 py-3 rounded-lg border border-white/10 hover:border-white/20 hover:bg-white/5 text-white font-medium transition">
          See how it works
        </a>
      </div>
      <p class="mt-4 text-xs text-[color:var(--color-muted)]">No credit card required · Cancel anytime · SOC 2 ready</p>

      <!-- Browser mockup -->
      <div class="mt-14 max-w-4xl mx-auto">
        <div class="card p-1.5 shadow-2xl shadow-indigo-500/10">
          <div class="flex items-center gap-1.5 px-3 py-2">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
            <span class="ml-3 text-xs text-[color:var(--color-muted)] font-mono">app.threadwise.com/search</span>
          </div>
          <div class="rounded-lg bg-[color:var(--color-bg-soft)] p-8 text-left grid md:grid-cols-3 gap-6">
            <div class="md:col-span-1 border-r border-white/5 pr-4 space-y-3">
              <div class="text-xs uppercase tracking-wider text-[color:var(--color-muted)] mb-2">Spaces</div>
              {['🚀 Engineering', '🎨 Design', '📊 Growth', '🧑‍💼 People Ops', '💰 Finance'].map(s => (
                <div class="text-sm text-white/80 hover:text-white cursor-pointer">{s}</div>
              ))}
            </div>
            <div class="md:col-span-2 space-y-4">
              <div class="flex items-center gap-2 bg-white/5 rounded-lg px-3 py-2">
                <span class="text-[color:var(--color-muted)]">🔎</span>
                <span class="text-sm text-white">How do we handle prod incidents?</span>
              </div>
              <div class="space-y-3">
                <div class="text-xs text-cyan-300 uppercase tracking-wider">AI answer · 3 sources</div>
                <p class="text-sm text-white/90 leading-relaxed">We follow the <span class="text-indigo-300 underline decoration-dotted">incident runbook</span> — page on-call via PagerDuty, open a thread in <span class="text-indigo-300 underline decoration-dotted">#incidents</span>, and update the status page within 10 minutes…</p>
                <div class="flex items-center gap-2 pt-2 border-t border-white/5">
                  <div class="w-6 h-6 rounded-full bg-gradient-to-br from-pink-400 to-purple-400"></div>
                  <span class="text-xs text-[color:var(--color-muted)]">Maya replied in thread · 2h ago</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- logo strip -->
      <div class="mt-16 opacity-70">
        <p class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-muted)] mb-6">Trusted by teams at</p>
        <div class="flex flex-wrap items-center justify-center gap-10 text-xl font-semibold text-white/40">
          <span>Loom Labs</span>
          <span>Northwind</span>
          <span>Helvetica</span>
          <span>Fernglow</span>
          <span>Quartzite</span>
          <span>Beacon&amp;Co</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm text-cyan-300 font-medium uppercase tracking-[0.2em]">Features</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Everything you need, nothing you don't.</h2>
        <p class="mt-4 text-[color:var(--color-muted)]">Four features, obsessively built. No bloated feature shelf.</p>
      </div>
      <div class="mt-14 grid md:grid-cols-2 gap-6">
        {features.map(f => (
          <div class="card card-hover p-8">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-xl font-semibold mb-2">{f.title}</h3>
            <p class="text-[color:var(--color-muted)] leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="py-24 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm text-cyan-300 font-medium uppercase tracking-[0.2em]">Customers</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Loved by teams that ship.</h2>
      </div>
      <div class="mt-14 grid md:grid-cols-3 gap-6">
        {(testimonials ?? []).map((t: Testimonial) => (
          <figure class="card p-8 flex flex-col">
            <blockquote class="text-white/90 leading-relaxed flex-1">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3 pt-6 border-t border-white/5">
              {t.avatar_url ? (
                <img src={t.avatar_url} alt={t.author} class="w-10 h-10 rounded-full" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-400 to-cyan-400"></div>
              )}
              <div>
                <div class="text-sm font-medium">{t.author}</div>
                <div class="text-xs text-[color:var(--color-muted)]">{t.role}{t.company ? ` · ${t.company}` : ''}</div>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-24 border-t border-white/5">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center">
        <p class="text-sm text-cyan-300 font-medium uppercase tracking-[0.2em]">FAQ</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Frequently asked.</h2>
      </div>
      <div class="mt-12 space-y-3">
        {(faqs ?? []).map((f: Faq) => (
          <details class="card p-6 group">
            <summary class="flex items-center justify-between gap-4">
              <span class="font-medium">{f.question}</span>
              <svg class="chev w-5 h-5 text-[color:var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="mt-3 text-[color:var(--color-muted)] leading-relaxed">{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- SIGNUP -->
  <section id="signup" class="py-24 border-t border-white/5">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm text-cyan-300 font-medium uppercase tracking-[0.2em]">Get started</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">Ready to stop losing knowledge?</h2>
      <p class="mt-4 text-[color:var(--color-muted)]">Drop your email — we'll set up your workspace and send you a setup guide.</p>

      <form id="lead-form" class="mt-10 card p-8 text-left space-y-4 max-w-xl mx-auto">
        <div class="grid sm:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Name</span>
            <input name="name" type="text" placeholder="Jane Doe" class="mt-2 w-full px-4 py-3 rounded-lg bg-black/40 border border-white/10 focus:border-indigo-400 focus:outline-none text-white" />
          </label>
          <label class="block">
            <span class="text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Company</span>
            <input name="company" type="text" placeholder="Acme Inc" class="mt-2 w-full px-4 py-3 rounded-lg bg-black/40 border border-white/10 focus:border-indigo-400 focus:outline-none text-white" />
          </label>
        </div>
        <label class="block">
          <span class="text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Work email *</span>
          <input required name="email" type="email" placeholder="jane@acme.com" class="mt-2 w-full px-4 py-3 rounded-lg bg-black/40 border border-white/10 focus:border-indigo-400 focus:outline-none text-white" />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-wider text-[color:var(--color-muted)]">Team size</span>
          <select name="team_size" class="mt-2 w-full px-4 py-3 rounded-lg bg-black/40 border border-white/10 focus:border-indigo-400 focus:outline-none text-white">
            <option value="">Select…</option>
            <option>1-10</option>
            <option>11-50</option>
            <option>51-200</option>
            <option>200+</option>
          </select>
        </label>
        <button type="submit" class="w-full px-6 py-3 rounded-lg bg-[color:var(--color-brand)] hover:bg-[color:var(--color-brand-hover)] text-white font-semibold transition shadow-lg shadow-indigo-500/30">
          Get early access
        </button>
        <p id="lead-msg" class="text-sm text-center hidden"></p>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const msg = document.getElementById('lead-msg') as HTMLParagraphElement | null;
  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const body = Object.fromEntries(fd.entries());
      msg.classList.remove('hidden');
      msg.textContent = 'Submitting…';
      msg.className = 'text-sm text-center text-[color:var(--color-muted)]';
      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Something went wrong');
        msg.textContent = '✅ You\'re in. Check your email for next steps.';
        msg.className = 'text-sm text-center text-emerald-400';
        form.reset();
      } catch (err: any) {
        msg.textContent = '❌ ' + (err?.message || 'Something went wrong');
        msg.className = 'text-sm text-center text-rose-400';
      }
    });
  }
</script>
