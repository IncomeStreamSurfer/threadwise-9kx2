---
import Base from '../layouts/Base.astro';
import { supabase, type Product } from '../lib/supabase';
import { formatGBP } from '../lib/money';

const { data } = await supabase
  .from('products')
  .select('*')
  .order('position', { ascending: true });

const products = (data ?? []) as Product[];

const pricingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Threadwise',
  description: 'AI-powered team knowledge base with threaded discussions',
  offers: products.map(p => ({
    '@type': 'Offer',
    name: p.name,
    price: (p.price_pence / 100).toString(),
    priceCurrency: p.currency.toUpperCase(),
    description: p.description,
  })),
};
---
<Base
  title="Threadwise Pricing — from £9 per seat/month"
  description="Simple per-seat pricing. Starter £9, Team £29, Enterprise £99. 14-day free trial on every plan."
  path="/pricing"
  jsonLd={pricingJsonLd}
>
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm text-cyan-300 font-medium uppercase tracking-[0.2em]">Pricing</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Simple per-seat pricing.</h1>
        <p class="mt-4 text-[color:var(--color-muted)]">All plans include unlimited documents, guest access and a 14-day free trial. Billed monthly in GBP. Cancel anytime.</p>
      </div>

      <div class="mt-14 grid md:grid-cols-3 gap-6">
        {products.map((p, idx) => {
          const featured = p.slug === 'team';
          return (
            <div class={`card p-8 flex flex-col relative ${featured ? 'ring-2 ring-indigo-400/60 shadow-2xl shadow-indigo-500/20' : ''}`}>
              {featured && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-indigo-500 text-xs font-semibold tracking-wide">
                  MOST POPULAR
                </div>
              )}
              <h2 class="text-xl font-bold">{p.name}</h2>
              <p class="mt-2 text-sm text-[color:var(--color-muted)] h-12">{p.description}</p>
              <div class="mt-6 flex items-baseline gap-2">
                <span class="text-5xl font-extrabold tracking-tight">{formatGBP(p.price_pence)}</span>
                <span class="text-[color:var(--color-muted)]">/seat/mo</span>
              </div>
              <form method="POST" action="/api/checkout" class="mt-6">
                <input type="hidden" name="product_slug" value={p.slug} />
                <div class="flex items-center gap-3 mb-4">
                  <label class="text-sm text-[color:var(--color-muted)]">Seats:</label>
                  <input name="quantity" type="number" min="1" max="500" value="5" class="w-20 px-3 py-2 rounded-lg bg-black/40 border border-white/10 text-white text-center" />
                </div>
                <button class={`w-full px-6 py-3 rounded-lg font-semibold transition ${featured ? 'bg-[color:var(--color-brand)] hover:bg-[color:var(--color-brand-hover)] text-white shadow-lg shadow-indigo-500/30' : 'bg-white/10 hover:bg-white/15 text-white border border-white/10'}`}>
                  Start {p.name} trial
                </button>
              </form>
              <ul class="mt-6 space-y-3 text-sm">
                {(p.features ?? []).map((f) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-white/90">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>

      <div class="mt-16 text-center text-sm text-[color:var(--color-muted)]">
        Need something custom? <a href="/#signup" class="text-indigo-300 hover:text-white underline">Talk to sales</a> · Annual billing available (20% off)
      </div>
    </div>
  </section>

  <!-- Compare table -->
  <section class="py-16 border-t border-white/5">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-center mb-10">Compare plans</h2>
      <div class="card overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/5 bg-white/5">
              <th class="text-left px-6 py-4 font-medium">Feature</th>
              {products.map(p => <th class="px-6 py-4 font-semibold">{p.name}</th>)}
            </tr>
          </thead>
          <tbody>
            {[
              ['Unlimited documents', true, true, true],
              ['Threaded discussions', true, true, true],
              ['AI semantic search', false, true, true],
              ['Slack / Drive integrations', true, true, true],
              ['Notion / Linear / GitHub sync', false, true, true],
              ['Role-based permissions', false, true, true],
              ['SSO / SAML', false, false, true],
              ['Audit logs', false, false, true],
              ['99.9% uptime SLA', false, false, true],
              ['Dedicated CSM', false, false, true],
            ].map((row, i) => (
              <tr class={`border-b border-white/5 ${i % 2 ? 'bg-white/[0.02]' : ''}`}>
                <td class="px-6 py-3 text-white/90">{row[0]}</td>
                {row.slice(1).map(v => (
                  <td class="px-6 py-3 text-center">
                    {v ? <span class="text-cyan-400">✓</span> : <span class="text-white/20">—</span>}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Base>
